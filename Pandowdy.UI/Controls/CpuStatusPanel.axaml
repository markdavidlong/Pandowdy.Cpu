<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Pandowdy.UI.ViewModels"
             x:Class="Pandowdy.UI.Controls.CpuStatusPanel"
             x:DataType="vm:CpuStatusPanelViewModel"
             Height="32">
    <Border Background="#1A1A1A" BorderBrush="#303030" BorderThickness="0,1,0,0" Padding="8,4">
        <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="PC:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PC, StringFormat=X4}" Foreground="#00FF00" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="A:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding A, StringFormat=X2}" Foreground="#FFFF00" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="X:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding X, StringFormat=X2}" Foreground="#FFFF00" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Y:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding Y, StringFormat=X2}" Foreground="#FFFF00" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="SP:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SP, StringFormat=X2}" Foreground="#FF8800" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StackSize}" Foreground="#666666" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" />
            </StackPanel>
            <Border Width="1" Background="#303030" Margin="4,0" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Flags:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagN, Mode=OneWay}" IsEnabled="False" Content="N" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagV, Mode=OneWay}" IsEnabled="False" Content="V" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagB, Mode=OneWay}" IsEnabled="False" Content="B" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagD, Mode=OneWay}" IsEnabled="False" Content="D" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagI, Mode=OneWay}" IsEnabled="False" Content="I" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagZ, Mode=OneWay}" IsEnabled="False" Content="Z" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
                <CheckBox IsChecked="{Binding FlagC, Mode=OneWay}" IsEnabled="False" Content="C" FontSize="10" Foreground="#CCCCCC" VerticalAlignment="Center" />
            </StackPanel>
            <Border Width="1" Background="#303030" Margin="4,0" />
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="Status:" Foreground="#888888" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}" Foreground="#00FFFF" FontFamily="Consolas" FontSize="12" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
