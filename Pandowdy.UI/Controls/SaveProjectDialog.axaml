<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Pandowdy.UI.ViewModels"
        x:Class="Pandowdy.UI.Controls.SaveProjectDialog"
        x:DataType="vm:SaveProjectDialogViewModel"
        Title="Save Project As"
        Width="560" Height="260"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Icon="/assets/ico/pandowdy.ico">

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16">

    <!-- Row 0: Project name -->
    <StackPanel Grid.Row="0" Spacing="4">
      <TextBlock Text="Project Name:" FontWeight="SemiBold" />
      <TextBox Text="{Binding ProjectName, Mode=TwoWay}"
               Watermark="Enter a project name"
               x:Name="ProjectNameBox" />
    </StackPanel>

    <!-- Row 1: Parent directory -->
    <StackPanel Grid.Row="1" Spacing="4" Margin="0,12,0,0">
      <TextBlock Text="Save Location:" FontWeight="SemiBold" />
      <Grid ColumnDefinitions="*,Auto">
        <TextBox Grid.Column="0"
                 Text="{Binding ParentDirectory, Mode=TwoWay}"
                 IsReadOnly="True"
                 Watermark="Choose a folder…" />
        <Button Grid.Column="1"
                Content="Browse…"
                Margin="8,0,0,0"
                Click="OnBrowseClick" />
      </Grid>
    </StackPanel>

    <!-- Row 2: Preview path -->
    <StackPanel Grid.Row="2" Spacing="2" Margin="0,12,0,0">
      <TextBlock Text="Will be saved as:" FontSize="11"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
      <TextBlock Text="{Binding PreviewPath}" FontSize="11"
                 TextWrapping="Wrap"
                 Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}" />
    </StackPanel>

    <!-- Row 3: Spacer -->

    <!-- Row 4: Buttons -->
    <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,12,0,0">
      <Button Content="Save"
              Command="{Binding SaveCommand}"
              IsDefault="True"
              Width="100" />
      <Button Content="Cancel"
              Command="{Binding CancelCommand}"
              IsCancel="True"
              Width="100" />
    </StackPanel>
  </Grid>
</Window>
