<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Pandowdy.UI.Controls"
             xmlns:viewmodels="clr-namespace:Pandowdy.UI.ViewModels"
             xmlns:converters="clr-namespace:Pandowdy.UI.Converters"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="32"
             x:Class="Pandowdy.UI.Controls.StatusBar"
             x:DataType="viewmodels:StatusBarViewModel">

  <UserControl.Resources>
    <converters:MhzDisplayConverter x:Key="MhzDisplayConverter"/>
  </UserControl.Resources>

  <!-- Status bar container with subtle border and background -->
  <Border BorderBrush="#303030" BorderThickness="0,1,0,0" Background="#1A1A1A">
    <Grid>
      <Grid.ColumnDefinitions>
        <!-- CPU Status takes available space -->
        <ColumnDefinition Width="*" />
        <!-- MHz Display - fixed width, right-aligned -->
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <!-- CPU Status Panel -->
      <controls:CpuStatusPanel x:Name="CpuStatusPanel" 
                               Grid.Column="0"
                               DataContext="{Binding CpuStatus}" />

      <!-- Current MHz Display - Right-aligned -->
      <StackPanel Grid.Column="1" 
                  Orientation="Horizontal" 
                  VerticalAlignment="Center"
                  Margin="8,0">
        <TextBlock Text="{Binding SystemStatus.StateCurrentMhz, Converter={StaticResource MhzDisplayConverter}}" 
                   Foreground="White" 
                   FontFamily="Consolas" 
                   FontSize="12" 
                   FontWeight="Bold"
                   VerticalAlignment="Center" />
        <TextBlock Text=" MHz" 
                   Foreground="#888888" 
                   FontFamily="Consolas" 
                   FontSize="12" 
                   VerticalAlignment="Center"
                   Margin="2,0,0,0" />
      </StackPanel>
    </Grid>
  </Border>
</UserControl>
