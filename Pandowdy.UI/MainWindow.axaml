<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:CompileBindings="False"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Pandowdy.UI"
		xmlns:viewmodels="clr-namespace:Pandowdy.UI.ViewModels"
		xmlns:controls="clr-namespace:Pandowdy.UI.Controls"
		mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="480"
		x:Class="Pandowdy.UI.MainWindow"
		Title="Pandowdy"
		MinWidth="800" MinHeight="600"
		WindowStartupLocation="Manual"
		Icon="assets/ico/pandowdy.ico"
		KeyDown="OnMainWindowKeyDown">
	<DockPanel>
		<Menu x:Name="MainMenu" DockPanel.Dock="Top" DataContext="{Binding}">
			<MenuItem Header="_File">
				<MenuItem Header="_Import Disk Image..." Click="OnImportDiskImageClicked" InputGesture="Ctrl+Shift+I" />
				<Separator />
				<MenuItem Header="_Quit" Click="OnQuitClicked" InputGesture="Alt+F4" />
			</MenuItem>

			<MenuItem Header="_Edit">
				<MenuItem Header="_Paste" Click="OnPasteClicked" InputGesture="Ctrl+Shift+V" />
			</MenuItem>

			<MenuItem Header="_Peripherals">
				<MenuItem Header="_Disks" ItemsSource="{Binding PeripheralsMenu.DiskMenuItems}">
					<MenuItem.Styles>
						<Style Selector="MenuItem">
							<Setter Property="Header" Value="{Binding Header}" />
							<Setter Property="ItemsSource" Value="{Binding Drives}" />
						</Style>
					</MenuItem.Styles>
				</MenuItem>
			</MenuItem>

			<MenuItem Header="_View">

				<MenuItem x:Name="ScanLinesMenuItem" Header="_Scan Lines" ToggleType="CheckBox" IsChecked="{Binding ShowScanLines}" Command="{Binding ToggleScanLines}" InputGesture="Ctrl+Alt+S" />
				<MenuItem x:Name="MonochromeMenuItem" Header="_Monochrome" ToggleType="CheckBox" IsChecked="{Binding ForceMonochrome}" Command="{Binding ToggleMonochrome}" InputGesture="Ctrl+Alt+M" />
				<MenuItem x:Name="MonoMixedMenuItem" Header="_Monochrome Mixed Text" ToggleType="CheckBox" IsChecked="{Binding MonoMixed}" Command="{Binding ToggleMonoMixed}" InputGesture="Ctrl+Alt+X" />
				<MenuItem x:Name="DecreaseFringingMenuItem" Header="_Decrease Color Fringing" ToggleType="CheckBox" IsChecked="{Binding DecreaseFringing}" Command="{Binding ToggleDecreaseFringing}" InputGesture="Ctrl+Alt+D"/>
				<Separator/>
				<MenuItem x:Name="ShowSoftSwitchStatusMenuItem" Header="Show SoftS_witch Status" ToggleType="CheckBox" IsChecked="{Binding ShowSoftSwitchStatus}" Command="{Binding ToggleSoftSwitchStatus}" InputGesture="Ctrl+Alt+W"/>
				<MenuItem x:Name="ShowDiskStatusMenuItem" Header="Show _Disk Status" ToggleType="CheckBox" IsChecked="{Binding ShowDiskStatus}" Command="{Binding ToggleDiskStatus}" InputGesture="Ctrl+Alt+K"/>
			</MenuItem>
			<MenuItem Header="_Emulator">
				<MenuItem Header="_Reset" Command="{Binding ResetEmu}" InputGesture="Ctrl+F12" />
				<Separator/>
				<MenuItem x:Name="ThrottleMenuItem" Header="_Throttle" ToggleType="CheckBox" IsChecked="{Binding ThrottleEnabled}" Command="{Binding ToggleThrottle}" InputGesture="F9" />
				<MenuItem x:Name="CapsLockMenuItem" Header="Caps _Lock" ToggleType="CheckBox" IsChecked="{Binding CapsLockEnabled}" Command="{Binding ToggleCapsLock}" InputGesture="F10" />
			</MenuItem>
			<MenuItem Header="_Debug">
				<MenuItem Header="{Binding PauseOrContinueText}" Command="{Binding TogglePauseOrContinue}" InputGesture="F5" />
				<Separator/>
				<MenuItem Header="_Step" Command="{Binding StepOnce}" InputGesture="F6" IsEnabled="{Binding CanStep}" />
			</MenuItem>
		</Menu>

		<!-- Status bar (bottom, full-width) -->
			<controls:StatusBar x:Name="StatusBar"
								DockPanel.Dock="Bottom"
								DataContext="{Binding StatusBar}" />

			<!-- Main content area with Grid layout for resizable panels -->
				<Grid x:Name="MainGrid">
					<Grid.ColumnDefinitions>
						<!-- Column 0: Main display area (takes remaining space) -->
						<ColumnDefinition Width="*" />
						<!-- Column 1: GridSplitter for disk panel resize -->
						<ColumnDefinition Width="Auto" />
						<!-- Column 2: Disk status panel (resizable, minimum 200px for card visibility) -->
						<ColumnDefinition Width="{Binding EffectiveDiskPanelWidth, Mode=TwoWay}" MinWidth="200" MaxWidth="400" />
						<!-- Column 3: GridSplitter for soft switch panel -->
						<ColumnDefinition Width="Auto" />
						<!-- Column 4: Soft switch status panel (fixed width) -->
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

				<!-- Apple2Display in column 0 -->
				<Border Grid.Column="0"
						Background="#D4C5A9" 
						Padding="16"
						CornerRadius="6"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Stretch">
					<Border Background="#222" 
							Padding="24"
							CornerRadius="6"
							HorizontalAlignment="Stretch"
							VerticalAlignment="Stretch">
						<Border Background="#000" 
								Padding="10"
								CornerRadius="6"
								HorizontalAlignment="Stretch"
								VerticalAlignment="Stretch">
							<local:Apple2Display x:Name="ScreenDisplay"  
												 HorizontalAlignment="Center"
												 VerticalAlignment="Center" />
						</Border>
					</Border>
				</Border>

				<!-- GridSplitter for disk panel in column 1 -->
				<GridSplitter Grid.Column="1"
								Width="4"
								Background="#404040"
								HorizontalAlignment="Center"
								VerticalAlignment="Stretch"
								IsVisible="{Binding ShowDiskStatus}" />

				<!-- Disk status panel in column 2 -->
				<controls:DiskStatusPanel Grid.Column="2"
											x:Name="DiskStatusPanel"
											DataContext="{Binding DiskStatus}"
											IsVisible="{Binding ShowDiskStatus}" />

				<!-- GridSplitter for soft switch panel in column 3 -->
				<GridSplitter Grid.Column="3"
								Width="4"
								Background="#404040"
								HorizontalAlignment="Center"
								VerticalAlignment="Stretch"
								IsVisible="{Binding ShowSoftSwitchStatus}" />

				<!-- Soft switch status panel in column 4 -->
				<local:SoftSwitchStatusPanel Grid.Column="4"
											 x:Name="SoftSwitchStatusPanel" 
											 DataContext="{Binding SystemStatus}"
											 IsVisible="{Binding ShowSoftSwitchStatus}" />
			</Grid>

		</DockPanel>

	<Window.Styles>
		<!-- styles omitted -->
	</Window.Styles>
</Window>
