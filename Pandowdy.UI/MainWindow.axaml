<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		x:CompileBindings="False"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:local="clr-namespace:Pandowdy.UI"
		xmlns:viewmodels="clr-namespace:Pandowdy.UI.ViewModels"
		mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="480"
		x:Class="Pandowdy.UI.MainWindow"
		Title="Pandowdy"
		Width="800" Height="600"
		MinWidth="800" MinHeight="600"
        Icon="assets/ico/pandowdy.ico"
		KeyDown="OnMainWindowKeyDown">
	<DockPanel>
		<Menu x:Name="MainMenu" DockPanel.Dock="Top" DataContext="{Binding}">
			<MenuItem Header="_File">
				<MenuItem Header="_Quit" Click="OnQuitClicked" InputGesture="Alt+F4" />
			</MenuItem>

			<MenuItem Header="_View">

				<MenuItem x:Name="ScanLinesMenuItem" Header="_Scan Lines" ToggleType="CheckBox" IsChecked="{Binding ShowScanLines}" Command="{Binding ToggleScanLines}" InputGesture="Alt+S" />
				<MenuItem x:Name="MonochromeMenuItem" Header="_Monochrome" ToggleType="CheckBox" IsChecked="{Binding ForceMonochrome}" Command="{Binding ToggleMonochrome}" InputGesture="Alt+M" />
				<MenuItem x:Name="MonoMixedMenuItem" Header="_Monochrome Mixed Text" ToggleType="CheckBox" IsChecked="{Binding MonoMixed}" Command="{Binding ToggleMonoMixed}" InputGesture="Alt+X" />
				<MenuItem x:Name="DecreaseContrastMenuItem" Header="_Decrease Color Fringing" ToggleType="CheckBox" IsChecked="{Binding DecreaseContrast}" Command="{Binding ToggleDecreaseContrast}" InputGesture="Alt+D"/>
				<Separator/>
				<MenuItem x:Name="ShowSoftSwitchStatusMenuItem" Header="Show SoftS_witch Status" ToggleType="CheckBox" IsChecked="{Binding ShowSoftSwitchStatus, RelativeSource={RelativeSource AncestorType=Window}}" Click="OnToggleSoftSwitchStatusClicked" InputGesture="Alt+W"/>
			</MenuItem>
			<MenuItem Header="_Emulator">
				<MenuItem Header="_Start" Command="{Binding StartEmu}" InputGesture="F5" />
				<MenuItem Header="S_top" Command="{Binding StopEmu}" InputGesture="Shift+F5" />
				<Separator/>
				<MenuItem Header="_Reset" Command="{Binding ResetEmu}" InputGesture="Ctrl+F12" />
				<MenuItem Header="Ste_p Once" Command="{Binding StepOnce}" InputGesture="F10" />
				<Separator/>
				<MenuItem x:Name="ThrottleMenuItem" Header="_Throttle" ToggleType="CheckBox" IsChecked="{Binding ThrottleEnabled}" Command="{Binding ToggleThrottle}" InputGesture="F7" />
				<MenuItem x:Name="CapsLockMenuItem" Header="Caps _Lock" ToggleType="CheckBox" IsChecked="{Binding CapsLockEnabled}" Command="{Binding ToggleCapsLock}" InputGesture="F6" />
			</MenuItem>
		</Menu>

		<!-- Right-side status panel sized to content only -->
		<Grid  x:Name="SoftSwitchStatusPanel" DockPanel.Dock="Right" ColumnDefinitions="Auto">
			<Border Padding="8" Margin="8" Background="#222" CornerRadius="4">
				<Grid RowDefinitions="Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto Auto auto auto auto auto auto Auto"
					  ColumnDefinitions="Auto Auto"
					  DataContext="{Binding SystemStatus}">
					<TextBlock Text="80STORE" Grid.Row="0" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding State80Store}" Grid.Row="0" Grid.Column="1" Foreground="White" />
					<TextBlock Text="RAMRD" Grid.Row="1" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateRamRd}" Grid.Row="1" Grid.Column="1" Foreground="White" />
					<TextBlock Text="RAMWRT" Grid.Row="2" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateRamWrt}" Grid.Row="2" Grid.Column="1" Foreground="White" />
					<TextBlock Text="INTCXROM" Grid.Row="3" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateIntCxRom}" Grid.Row="3" Grid.Column="1" Foreground="White" />
					<TextBlock Text="ALTZP" Grid.Row="4" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateAltZp}" Grid.Row="4" Grid.Column="1" Foreground="White" />
					<TextBlock Text="SLOT C3" Grid.Row="5" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateSlotC3Rom}" Grid.Row="5" Grid.Column="1" Foreground="White" />
					<TextBlock Text="PB0" Grid.Row="6" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StatePb0}" Grid.Row="6" Grid.Column="1" Foreground="White" />
					<TextBlock Text="PB1" Grid.Row="7" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StatePb1}" Grid.Row="7" Grid.Column="1" Foreground="White" />
					<TextBlock Text="PB2" Grid.Row="8" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StatePb2}" Grid.Row="8" Grid.Column="1" Foreground="White" />
					<TextBlock Text="ANN0" Grid.Row="9" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateAnn0}" Grid.Row="9" Grid.Column="1" Foreground="White" />
					<TextBlock Text="ANN1" Grid.Row="10" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateAnn1}" Grid.Row="10" Grid.Column="1" Foreground="White" />
					<TextBlock Text="ANN2" Grid.Row="11" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateAnn2}" Grid.Row="11" Grid.Column="1" Foreground="White" />
					<TextBlock Text="ANN3/DGR" Grid.Row="12" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateAnn3}" Grid.Row="12" Grid.Column="1" Foreground="White" />
					<TextBlock Text="PAGE2" Grid.Row="13" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StatePage2}" Grid.Row="13" Grid.Column="1" Foreground="White" />
					<TextBlock Text="HIRES" Grid.Row="14" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateHiRes}" Grid.Row="14" Grid.Column="1" Foreground="White" />
					<TextBlock Text="MIXED" Grid.Row="15" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateMixed}" Grid.Row="15" Grid.Column="1" Foreground="White" />
					<TextBlock Text="TEXT" Grid.Row="16" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateTextMode}" Grid.Row="16" Grid.Column="1" Foreground="White" />
					<TextBlock Text="ALTCHAR" Grid.Row="17" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateAltCharSet}" Grid.Row="17" Grid.Column="1" Foreground="White" />

					<TextBlock Text="Show 80 Col" Grid.Row="18" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateShow80Col}" Grid.Row="18" Grid.Column="1" Foreground="White" />

					<TextBlock Text="Bank 1" Grid.Row="19" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateBank1}" Grid.Row="19" Grid.Column="1" Foreground="White" />

					<TextBlock Text="High Read" Grid.Row="20" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateHighRead}" Grid.Row="20" Grid.Column="1" Foreground="White" />

					<TextBlock Text="High Write" Grid.Row="21" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateHighWrite}" Grid.Row="21" Grid.Column="1" Foreground="White" />

					<TextBlock Text="PreWrite" Grid.Row="22" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StatePrewrite}" Grid.Row="22" Grid.Column="1" Foreground="White" />

					<TextBlock Text="FLASH ON" Grid.Row="23" Grid.Column="0" Foreground="LightGray" Margin="0,0,8,2" />
					<TextBlock Text="{Binding StateFlashOn}" Grid.Row="23" Grid.Column="1" Foreground="White" />
				</Grid>
			</Border>
		</Grid>

		<!-- Apple2Display centered with black background, padding, margin, and rounded corners -->
<Border Background="#D4C5A9" 
        Padding="16"
        CornerRadius="6"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch">
    <Border Background="#222" 
            Padding="24"
            CornerRadius="6"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Border Background="#000" 
                Padding="10"
                CornerRadius="6"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">
            <local:Apple2Display x:Name="ScreenDisplay"  
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center" 
                              />
        </Border>
    </Border>
</Border>

	</DockPanel>

	<Window.Styles>
		<!-- styles omitted -->
	</Window.Styles>
</Window>
