<UserControl xmlns="https://github.com/avaloniaui"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:viewmodels="clr-namespace:Pandowdy.UI.ViewModels"
         xmlns:converters="clr-namespace:Pandowdy.UI.Converters"
         mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="600"
         x:Class="Pandowdy.UI.SoftSwitchStatusPanel"
         x:DataType="viewmodels:SystemStatusViewModel">
    
<UserControl.Resources>
    <converters:FlagBackgroundConverter x:Key="FlagBg"/>
    <converters:FlagForegroundConverter x:Key="FlagFg"/>
</UserControl.Resources>

<UserControl.Styles>
    <!-- Style for flag indicators with smooth color transitions -->
    <Style Selector="Border.flag-indicator">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.125"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- Style for text inside flag indicators with smooth foreground transitions -->
    <Style Selector="Border.flag-indicator TextBlock">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.125"/>
            </Transitions>
        </Setter>
    </Style>
</UserControl.Styles>
    
<Border Padding="8" Margin="8" Background="#222" CornerRadius="4">
        <StackPanel Spacing="2">
            <!-- 80STORE Flag -->
            <Border Classes="flag-indicator" Background="{Binding State80Store, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="80-Column Store">
                <TextBlock Text="80STORE" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding State80Store, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- RAMRD Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateRamRd, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Read from Auxiliary RAM">
                <TextBlock Text="RAMRD" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateRamRd, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- RAMWRT Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateRamWrt, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Write to Auxiliary RAM">
                <TextBlock Text="RAMWRT" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateRamWrt, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- INTCXROM Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateIntCxRom, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Internal CX ROM">
                <TextBlock Text="INTCXROM" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateIntCxRom, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- ALTZP Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateAltZp, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Alternate Zero Page">
                <TextBlock Text="ALTZP" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateAltZp, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- SLOT C3 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateSlotC3Rom, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Slot C3 ROM">
                <TextBlock Text="SLOT C3" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateSlotC3Rom, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- PB0 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StatePb0, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Paddle Button 0">
                <TextBlock Text="PB0" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StatePb0, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- PB1 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StatePb1, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Paddle Button 1">
                <TextBlock Text="PB1" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StatePb1, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- PB2 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StatePb2, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Paddle Button 2">
                <TextBlock Text="PB2" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StatePb2, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- ANN0 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateAnn0, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Annunciator 0">
                <TextBlock Text="ANN0" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateAnn0, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- ANN1 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateAnn1, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Annunciator 1">
                <TextBlock Text="ANN1" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateAnn1, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- ANN2 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateAnn2, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Annunciator 2">
                <TextBlock Text="ANN2" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateAnn2, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- ANN3/DGR Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateAnn3, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Annunciator 3 / Double Graphics">
                <TextBlock Text="ANN3/DGR" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateAnn3, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- PAGE2 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StatePage2, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Page 2 Video Memory">
                <TextBlock Text="PAGE2" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StatePage2, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- HIRES Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateHiRes, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="High Resolution Graphics">
                <TextBlock Text="HIRES" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateHiRes, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- MIXED Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateMixed, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Mixed Graphics/Text Mode">
                <TextBlock Text="MIXED" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateMixed, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- TEXT Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateTextMode, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Text Mode">
                <TextBlock Text="TEXT" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateTextMode, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- ALTCHAR Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateAltCharSet, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Alternate Character Set">
                <TextBlock Text="ALTCHAR" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateAltCharSet, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- Show 80 Col Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateShow80Col, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Show 80 Column Mode">
                <TextBlock Text="80 COL" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateShow80Col, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- Bank 1 Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateBank1, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Language Card Bank 1">
                <TextBlock Text="BANK 1" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateBank1, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- High Read Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateHighRead, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Language Card High Read">
                <TextBlock Text="HIGH READ" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateHighRead, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- High Write Flag -->
            <Border Classes="flag-indicator" Background="{Binding StateHighWrite, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Language Card High Write">
                <TextBlock Text="HIGH WRITE" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateHighWrite, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- PreWrite Flag -->
            <Border Classes="flag-indicator" Background="{Binding StatePrewrite, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Language Card Pre-write State">
                <TextBlock Text="PREWRITE" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StatePrewrite, Converter={StaticResource FlagFg}}" />
            </Border>

            <!-- FLASH ON Flag
            <Border Background="{Binding StateFlashOn, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Flash State (for blinking text)">
                <TextBlock Text="FLASH ON" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateFlashOn, Converter={StaticResource FlagFg}}" />
            </Border>
            -->

            <!-- VBLANK Flag
            <Border Classes="flag-indicator" Background="{Binding StateVBlank, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Vertical Blanking">
                <TextBlock Text="VBLANK" FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateVBlank, Converter={StaticResource FlagFg}}" />
            </Border>
            -->

            <!-- INTC8ROM Flag
            <Border Classes="flag-indicator" Background="{Binding StateIntC8Rom, Converter={StaticResource FlagBg}}" 
                    CornerRadius="2" Padding="4,1" ToolTip.Tip="Internal C8 ROM">
            <Grid ColumnDefinitions="Auto,Auto" >
                <TextBlock Text="INTC8ROM: " FontFamily="Consolas" Grid.Column="0"  FontSize="11" FontWeight="Bold"
                           Foreground="{Binding StateIntC8Rom, Converter={StaticResource FlagFg}}" />
                <TextBlock Text="{Binding StateIntC8RomSlot}" Grid.Column="1" Foreground="{Binding StateIntC8Rom, Converter={StaticResource FlagFg}}"
                           FontFamily="Consolas" FontSize="11" FontWeight="Bold" />
            </Grid>
            </Border>
            -->

   
        </StackPanel>
    </Border>
</UserControl>
